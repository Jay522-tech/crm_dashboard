PORT=5000
MONGODB_URI=mongodb://localhost:27017/crm
JWT_SECRET=change_this_secret

# Frontend CORS origin(s), comma-separated if multiple.
# Supports wildcard like https://*.vercel.app for preview deployments.
FRONTEND_ORIGIN=http://localhost:5173

# SMTP settings for event reminder emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM="CRM Dashboard <your_email@example.com>"

